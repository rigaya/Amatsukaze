@page "/trim-adjust/{QueueItemId:int}"
@using Amatsukaze.Shared
@using Microsoft.AspNetCore.Components.Web
@using System.Globalization
@using System.Text.Json
@using System.Threading
@inject IAmatsukazeApi Api
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="trim-adjust-page" @onkeydown="OnKeyDown" @onkeydown:preventDefault="true" tabindex="0" @ref="_pageRef">
    <div class="trim-toolbar">
        <button class="trim-btn trim-btn-sm" @onclick="ShowCheckLog" title="CM解析チェックログ">ログ</button>
        <button class="trim-btn trim-btn-primary" @onclick="SaveTrims" disabled="@(!_hasChanges)">保存</button>
        <div class="trim-toolbar-requeue">
            <select class="trim-profile-select" @bind="_selectedProfile" disabled="@(_profiles == null || _profiles.Count == 0)">
                @if (_profiles != null)
                {
                    @foreach (var name in _profiles)
                    {
                        <option value="@name">@name</option>
                    }
                }
            </select>
            <button class="trim-btn trim-btn-sm" @onclick="RequeueWithProfile"
                    disabled="@(_requeueBusy || string.IsNullOrEmpty(_selectedProfile))"
                    title="保存してプロファイルを変更し通常モードで再投入">
                @(_requeueBusy ? "処理中..." : "保存して再投入")
            </button>
        </div>
        <span class="trim-toolbar-info">
            @if (!string.IsNullOrEmpty(_statusMessage))
            {
                <span class="@(_isError ? "trim-status-error" : "trim-status-ok")">@_statusMessage</span>
            }
        </span>
    </div>

    @if (_loading)
    {
        <div class="trim-loading">読み込み中...</div>
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="trim-error">@_errorMessage</div>
    }
    else if (_session != null)
    {
        <div class="trim-main">
            @* 左: 編集点リスト *@
            <div class="trim-editpoints">
                <div class="trim-editpoints-header">編集点</div>
                <div class="trim-editpoints-list">
                    @{
                        var segments = BuildEditPointSegments();
                    }
                    @for (int i = 0; i < segments.Count; i++)
                    {
                        var idx = i;
                        var segment = segments[idx];
                        <div class="trim-editpoint @(segment.IsMain ? "trim-editpoint-main" : "") @(idx == _selectedEditPoint ? "selected" : "")"
                             @onclick="(() => OnEditPointClick(idx))">
                            <span class="trim-ep-index">@(idx + 1).</span>
                            <span class="trim-ep-frame">@segment.Start</span>
                            <span class="trim-ep-tail">@GetEditPointSegmentTail(segment)</span>
                        </div>
                    }
                </div>
                <div class="trim-editpoints-actions">
                    <button class="trim-btn trim-btn-sm" @onclick="ResetEditPoints"
                            disabled="@(!_hasChanges)">リセット</button>
                </div>
            </div>

            @* 右: プレビュー + コントロール *@
            <div class="trim-preview-area">
                @* 映像プレビュー *@
                <div class="trim-preview-container">
                    <img class="trim-preview-img"
                         src="@_frameImageUrl"
                         alt="Frame @_currentFrame"
                         @ref="_imgRef" />
                    <div class="trim-preview-frame-overlay @(IsFrameInTrimRange(_displayedFrame) ? "trim-range-active" : "trim-range-cut")">
                        @_displayedFrame
                    </div>
                    @if (_sessionExpired)
                    {
                        <div class="trim-session-expired-overlay">
                            <div class="trim-session-expired-box">
                                <div>セッションが切れました</div>
                                <button class="trim-btn trim-btn-primary" @onclick="ReconnectSessionAsync"
                                        disabled="@_reconnecting">
                                    @(_reconnecting ? "再接続中..." : "再接続")
                                </button>
                                @if (!string.IsNullOrEmpty(_reconnectError))
                                {
                                    <div class="trim-status-error">@_reconnectError</div>
                                }
                            </div>
                        </div>
                    }
                </div>

                @* 音声波形 *@
                <div class="trim-waveform-container">
                    <img class="trim-waveform-img"
                         src="@_waveformImageUrl"
                         alt="Waveform" />
                </div>

                @* フレーム情報 *@
                <div class="trim-frame-info">
                    <span>Frame: @_currentFrame</span>
                    <span> | </span>
                    <span>@FormatTime(_currentFrame)</span>
                </div>

                @* 移動ボタン *@
                <div class="trim-controls">
                    <button class="trim-control-btn"
                            @onclick="() => ExecuteTrimCommand(TrimCmdPrevEditPoint)"
                            title="@GetTrimCommandTooltip(TrimCmdPrevEditPoint)"
                            aria-label="@GetTrimCommandTooltip(TrimCmdPrevEditPoint)">
                        <span class="trim-control-icon trim-control-icon-left">
                            <span class="trim-icon-bar"></span>
                            <span class="trim-icon-chevron"></span>
                        </span>
                        <span class="trim-control-distance">@GetTrimCommandDistanceLabel(TrimCmdPrevEditPoint)</span>
                    </button>
                    <button class="trim-control-btn"
                            @onclick="() => ExecuteTrimCommand(TrimCmdBack4)"
                            title="@GetTrimCommandTooltip(TrimCmdBack4)"
                            aria-label="@GetTrimCommandTooltip(TrimCmdBack4)">
                        <span class="trim-control-icon trim-control-icon-left">
                            <span class="trim-icon-chevron"></span>
                            <span class="trim-icon-chevron"></span>
                            <span class="trim-icon-chevron"></span>
                            <span class="trim-icon-chevron"></span>
                        </span>
                        <span class="trim-control-distance">@GetTrimCommandDistanceLabel(TrimCmdBack4)</span>
                    </button>
                    <button class="trim-control-btn"
                            @onclick="() => ExecuteTrimCommand(TrimCmdBack3)"
                            title="@GetTrimCommandTooltip(TrimCmdBack3)"
                            aria-label="@GetTrimCommandTooltip(TrimCmdBack3)">
                        <span class="trim-control-icon trim-control-icon-left">
                            <span class="trim-icon-chevron"></span>
                            <span class="trim-icon-chevron"></span>
                            <span class="trim-icon-chevron"></span>
                        </span>
                        <span class="trim-control-distance">@GetTrimCommandDistanceLabel(TrimCmdBack3)</span>
                    </button>
                    <button class="trim-control-btn"
                            @onclick="() => ExecuteTrimCommand(TrimCmdBack2)"
                            title="@GetTrimCommandTooltip(TrimCmdBack2)"
                            aria-label="@GetTrimCommandTooltip(TrimCmdBack2)">
                        <span class="trim-control-icon trim-control-icon-left">
                            <span class="trim-icon-chevron"></span>
                            <span class="trim-icon-chevron"></span>
                        </span>
                        <span class="trim-control-distance">@GetTrimCommandDistanceLabel(TrimCmdBack2)</span>
                    </button>
                    <button class="trim-control-btn"
                            @onclick="() => ExecuteTrimCommand(TrimCmdBack1)"
                            title="@GetTrimCommandTooltip(TrimCmdBack1)"
                            aria-label="@GetTrimCommandTooltip(TrimCmdBack1)">
                        <span class="trim-control-icon trim-control-icon-left">
                            <span class="trim-icon-chevron"></span>
                        </span>
                        <span class="trim-control-distance">@GetTrimCommandDistanceLabel(TrimCmdBack1)</span>
                    </button>
                    <button class="trim-control-btn @(IsCurrentFrameEditPoint() ? "trim-btn-active" : "")"
                            @onclick="() => ExecuteTrimCommand(TrimCmdToggleEditPoint)"
                            title="@GetTrimCommandTooltip(TrimCmdToggleEditPoint)"
                            aria-label="@GetTrimCommandTooltip(TrimCmdToggleEditPoint)">
                        <span class="trim-control-icon trim-control-icon-toggle">
                            <span class="trim-icon-bar"></span>
                            <span class="trim-icon-dot"></span>
                        </span>
                        <span class="trim-control-distance">@GetTrimCommandDistanceLabel(TrimCmdToggleEditPoint)</span>
                    </button>
                    <button class="trim-control-btn"
                            @onclick="() => ExecuteTrimCommand(TrimCmdForward1)"
                            title="@GetTrimCommandTooltip(TrimCmdForward1)"
                            aria-label="@GetTrimCommandTooltip(TrimCmdForward1)">
                        <span class="trim-control-icon trim-control-icon-right">
                            <span class="trim-icon-chevron"></span>
                        </span>
                        <span class="trim-control-distance">@GetTrimCommandDistanceLabel(TrimCmdForward1)</span>
                    </button>
                    <button class="trim-control-btn"
                            @onclick="() => ExecuteTrimCommand(TrimCmdForward2)"
                            title="@GetTrimCommandTooltip(TrimCmdForward2)"
                            aria-label="@GetTrimCommandTooltip(TrimCmdForward2)">
                        <span class="trim-control-icon trim-control-icon-right">
                            <span class="trim-icon-chevron"></span>
                            <span class="trim-icon-chevron"></span>
                        </span>
                        <span class="trim-control-distance">@GetTrimCommandDistanceLabel(TrimCmdForward2)</span>
                    </button>
                    <button class="trim-control-btn"
                            @onclick="() => ExecuteTrimCommand(TrimCmdForward3)"
                            title="@GetTrimCommandTooltip(TrimCmdForward3)"
                            aria-label="@GetTrimCommandTooltip(TrimCmdForward3)">
                        <span class="trim-control-icon trim-control-icon-right">
                            <span class="trim-icon-chevron"></span>
                            <span class="trim-icon-chevron"></span>
                            <span class="trim-icon-chevron"></span>
                        </span>
                        <span class="trim-control-distance">@GetTrimCommandDistanceLabel(TrimCmdForward3)</span>
                    </button>
                    <button class="trim-control-btn"
                            @onclick="() => ExecuteTrimCommand(TrimCmdForward4)"
                            title="@GetTrimCommandTooltip(TrimCmdForward4)"
                            aria-label="@GetTrimCommandTooltip(TrimCmdForward4)">
                        <span class="trim-control-icon trim-control-icon-right">
                            <span class="trim-icon-chevron"></span>
                            <span class="trim-icon-chevron"></span>
                            <span class="trim-icon-chevron"></span>
                            <span class="trim-icon-chevron"></span>
                        </span>
                        <span class="trim-control-distance">@GetTrimCommandDistanceLabel(TrimCmdForward4)</span>
                    </button>
                    <button class="trim-control-btn"
                            @onclick="() => ExecuteTrimCommand(TrimCmdNextEditPoint)"
                            title="@GetTrimCommandTooltip(TrimCmdNextEditPoint)"
                            aria-label="@GetTrimCommandTooltip(TrimCmdNextEditPoint)">
                        <span class="trim-control-icon trim-control-icon-right">
                            <span class="trim-icon-chevron"></span>
                            <span class="trim-icon-bar"></span>
                        </span>
                        <span class="trim-control-distance">@GetTrimCommandDistanceLabel(TrimCmdNextEditPoint)</span>
                    </button>
                </div>

                @* シークバー *@
                <div class="trim-seekbar-container">
                    <div class="trim-seekbar" @ref="_seekBarRef">
                        <div class="trim-seekbar-bg" style="@GetSeekBarGradient()"></div>
                        @* 現在位置マーカー *@
                        <div class="trim-seekbar-cursor"
                             style="left: @(GetFramePercent(_currentFrame))%"></div>
                        @* 編集点マーカー（▽表示のみ、クリックはJS側で処理） *@
                        @foreach (var ep in _editPoints)
                        {
                            var epFrame = ep.Frame;
                            <div class="trim-seekbar-marker"
                                 style="left: @(GetFramePercent(epFrame))%"></div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @* チェックログオーバーレイ *@
    @if (_checkLogVisible)
    {
        <div class="trim-log-overlay" @onclick="CloseCheckLog">
            <div class="trim-log-overlay-panel" @onclick:stopPropagation="true">
                <button class="trim-log-overlay-close" type="button" @onclick="CloseCheckLog">&times;</button>
                <h4>CM解析チェックログ</h4>
                @if (_checkLogLoading)
                {
                    <p>読み込み中...</p>
                }
                else if (!string.IsNullOrEmpty(_checkLogError))
                {
                    <p style="color: red;">@_checkLogError</p>
                }
                else if (_checkLogContent == null)
                {
                    <p>チェックログが見つかりません</p>
                }
                else
                {
                    <div class="trim-log-content">
                        <div>@_checkLogTitle</div>
                        @if (_checkLogContent.Meta?.TooLarge == true)
                        {
                            <div>(truncated)</div>
                        }
                        <pre class="trim-log-detail">@(_checkLogContent.Content ?? "")</pre>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int QueueItemId { get; set; }

    private const string TrimCmdPrevEditPoint = "PrevEditPoint";
    private const string TrimCmdBack4 = "Back4";
    private const string TrimCmdBack3 = "Back3";
    private const string TrimCmdBack2 = "Back2";
    private const string TrimCmdBack1 = "Back1";
    private const string TrimCmdForward1 = "Forward1";
    private const string TrimCmdForward2 = "Forward2";
    private const string TrimCmdForward3 = "Forward3";
    private const string TrimCmdForward4 = "Forward4";
    private const string TrimCmdNextEditPoint = "NextEditPoint";
    private const string TrimCmdToggleEditPoint = "ToggleEditPoint";

    private const string TrimAdjustShortcutPrevEditPointField = "TrimAdjustShortcutPrevEditPoint";
    private const string TrimAdjustShortcutBack4Field = "TrimAdjustShortcutBack4";
    private const string TrimAdjustShortcutBack3Field = "TrimAdjustShortcutBack3";
    private const string TrimAdjustShortcutBack2Field = "TrimAdjustShortcutBack2";
    private const string TrimAdjustShortcutBack1Field = "TrimAdjustShortcutBack1";
    private const string TrimAdjustShortcutForward1Field = "TrimAdjustShortcutForward1";
    private const string TrimAdjustShortcutForward2Field = "TrimAdjustShortcutForward2";
    private const string TrimAdjustShortcutForward3Field = "TrimAdjustShortcutForward3";
    private const string TrimAdjustShortcutForward4Field = "TrimAdjustShortcutForward4";
    private const string TrimAdjustShortcutNextEditPointField = "TrimAdjustShortcutNextEditPoint";
    private const string TrimAdjustShortcutToggleEditPointField = "TrimAdjustShortcutToggleEditPoint";
    private const string TrimAdjustPreviewScaleModeField = "TrimAdjustPreviewScaleMode";
    private const string TrimAdjustMoveFramesBack4Field = "TrimAdjustMoveFramesBack4";
    private const string TrimAdjustMoveFramesBack3Field = "TrimAdjustMoveFramesBack3";
    private const string TrimAdjustMoveFramesBack2Field = "TrimAdjustMoveFramesBack2";
    private const string TrimAdjustMoveFramesForward2Field = "TrimAdjustMoveFramesForward2";
    private const string TrimAdjustMoveFramesForward3Field = "TrimAdjustMoveFramesForward3";
    private const string TrimAdjustMoveFramesForward4Field = "TrimAdjustMoveFramesForward4";

    private sealed class TrimCommandSetting
    {
        public string CommandId { get; }
        public string ShortcutField { get; }
        public string DefaultShortcut { get; }
        public string? MoveFramesField { get; }
        public int DefaultMoveFrames { get; }

        public TrimCommandSetting(string commandId, string shortcutField, string defaultShortcut, string? moveFramesField, int defaultMoveFrames)
        {
            CommandId = commandId;
            ShortcutField = shortcutField;
            DefaultShortcut = defaultShortcut;
            MoveFramesField = moveFramesField;
            DefaultMoveFrames = defaultMoveFrames;
        }
    }

    private static readonly TrimCommandSetting[] _trimCommandSettings = new[]
    {
        new TrimCommandSetting(TrimCmdPrevEditPoint, TrimAdjustShortcutPrevEditPointField, "ArrowUp", null, 0),
        new TrimCommandSetting(TrimCmdBack4, TrimAdjustShortcutBack4Field, "Alt+ArrowLeft", TrimAdjustMoveFramesBack4Field, 900),
        new TrimCommandSetting(TrimCmdBack3, TrimAdjustShortcutBack3Field, "Shift+ArrowLeft", TrimAdjustMoveFramesBack3Field, 450),
        new TrimCommandSetting(TrimCmdBack2, TrimAdjustShortcutBack2Field, "Ctrl+ArrowLeft", TrimAdjustMoveFramesBack2Field, 300),
        new TrimCommandSetting(TrimCmdBack1, TrimAdjustShortcutBack1Field, "ArrowLeft", null, 1),
        new TrimCommandSetting(TrimCmdForward1, TrimAdjustShortcutForward1Field, "ArrowRight", null, 1),
        new TrimCommandSetting(TrimCmdForward2, TrimAdjustShortcutForward2Field, "Ctrl+ArrowRight", TrimAdjustMoveFramesForward2Field, 300),
        new TrimCommandSetting(TrimCmdForward3, TrimAdjustShortcutForward3Field, "Shift+ArrowRight", TrimAdjustMoveFramesForward3Field, 450),
        new TrimCommandSetting(TrimCmdForward4, TrimAdjustShortcutForward4Field, "Alt+ArrowRight", TrimAdjustMoveFramesForward4Field, 900),
        new TrimCommandSetting(TrimCmdNextEditPoint, TrimAdjustShortcutNextEditPointField, "ArrowDown", null, 0),
        new TrimCommandSetting(TrimCmdToggleEditPoint, TrimAdjustShortcutToggleEditPointField, "Space", null, 0)
    };

    private static readonly Dictionary<string, TrimCommandSetting> _trimCommandSettingMap = _trimCommandSettings
        .ToDictionary(item => item.CommandId, item => item, StringComparer.Ordinal);

    private ElementReference _pageRef;
    private ElementReference _seekBarRef;
    private ElementReference _imgRef;

    private bool _loading = true;
    private string? _errorMessage;
    private string? _statusMessage;
    private bool _isError;
    private bool _hasChanges;

    // セッション切れ検出・再接続用
    private bool _sessionExpired;
    private bool _reconnecting;
    private string? _reconnectError;
    private DotNetObjectReference<TrimAdjust>? _objRef;
    private bool _imgErrorHandlerSet;
    private bool _seekbarHandlerSet;
    private bool _wheelHandlerSet;

    private TrimAdjustSessionResponse? _session;
    private string? _sessionId;
    private int _currentFrame;
    private string _frameImageUrl = "";
    private string _waveformImageUrl = "";
    private int _bundleRequestToken;
    private int _displayedFrame; // 画像読み込み完了と同期して表示するフレーム番号
    private int _loadingFrame; // 現在img srcにセットして読み込み中のフレーム
    private bool _isFrameLoading; // 画像読み込み中フラグ

    // 編集点リスト（境界開始フレーム）
    private List<EditPoint> _editPoints = new List<EditPoint>();
    private List<EditPoint> _initialEditPoints = new List<EditPoint>(); // 初期ロード時の編集点（リセット用）
    private int _selectedEditPoint = -1;

    // プロファイル選択・再投入
    private List<string> _profiles = new List<string>();
    private string? _selectedProfile;
    private bool _requeueBusy;

    // チェックログオーバーレイ
    private bool _checkLogVisible;
    private bool _checkLogLoading;
    private string? _checkLogError;
    private string? _checkLogTitle;
    private LogFileContent? _checkLogContent;
    private string? _queueItemSrcPath; // キューアイテムのソースパス（チェックログ検索・再投入用）
    private string? _queueItemOutDir; // 再投入時の出力先フォルダ
    private int _queueItemPriority = 3; // 再投入時に引き継ぐ優先度

    // debounce用タイマー
    private System.Threading.Timer? _debounceTimer;
    private int _pendingFrame = -1;
    private readonly Dictionary<string, string> _shortcutByCommand = new Dictionary<string, string>(StringComparer.Ordinal);
    private readonly Dictionary<string, int> _moveFramesByCommand = new Dictionary<string, int>(StringComparer.Ordinal);
    private readonly Dictionary<string, string> _commandByShortcut = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
    private int _previewScaleMode = 1;

    private class EditPoint
    {
        public int Frame { get; set; }
    }

    private sealed class EditPointSegment
    {
        public int Index { get; set; } // 0-based
        public int Start { get; set; }
        public int EndInclusive { get; set; }
        public bool IsOpenEnded { get; set; }
        public bool IsMain => (Index % 2) == 0; // 1始まり奇数区間=本編
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _objRef = DotNetObjectReference.Create(this);
            await _pageRef.FocusAsync();
            await LoadSessionAsync();
        }
        // セッション確立後、JSハンドラを設定
        if (_session != null && !_sessionExpired)
        {
            try
            {
                if (!_imgErrorHandlerSet)
                {
                    await JS.InvokeVoidAsync("trimAdjustSetupImgHandler", _objRef);
                    _imgErrorHandlerSet = true;
                }
                if (!_seekbarHandlerSet)
                {
                    await JS.InvokeVoidAsync("trimAdjustSetupSeekbar", _objRef);
                    _seekbarHandlerSet = true;
                }
                if (!_wheelHandlerSet)
                {
                    await JS.InvokeVoidAsync("trimAdjustSetupWheel", _objRef);
                    _wheelHandlerSet = true;
                }
            }
            catch
            {
                // 初回レンダリング前はDOM未準備の可能性
            }
        }
    }

    [JSInvokable]
    public void OnFrameLoaded()
    {
        InvokeAsync(() =>
        {
            _displayedFrame = _loadingFrame;
            _isFrameLoading = false;
            // まだ新しいフレームが要求されていれば続けてロード
            if (_currentFrame != _loadingFrame)
            {
                RequestFrameLoad();
            }
            else
            {
                StateHasChanged();
            }
        });
    }

    [JSInvokable]
    public void OnFrameLoadError()
    {
        InvokeAsync(() =>
        {
            if (string.IsNullOrEmpty(_frameImageUrl) || _frameImageUrl.StartsWith("data:", StringComparison.OrdinalIgnoreCase))
            {
                return;
            }
            _isFrameLoading = false;
            if (!_sessionExpired && !_loading)
            {
                _sessionExpired = true;
                StateHasChanged();
            }
        });
    }

    [JSInvokable]
    public void OnSeekBarDrag(double ratio)
    {
        if (_session == null || _session.NumFrames <= 1) return;
        ratio = Math.Clamp(ratio, 0, 1);
        var targetFrame = (int)(ratio * (_session.NumFrames - 1));
        InvokeAsync(() =>
        {
            SetCurrentFrameDebounced(targetFrame);
        });
    }

    // ▽マーカー領域クリック: 最寄りの編集点にスナップ
    [JSInvokable]
    public void OnSeekBarMarkerClick(double ratio)
    {
        if (_session == null || _session.NumFrames <= 1 || _editPoints.Count == 0) return;
        ratio = Math.Clamp(ratio, 0, 1);
        var targetFrame = (int)(ratio * (_session.NumFrames - 1));
        InvokeAsync(() =>
        {
            var nearest = _editPoints.OrderBy(ep => Math.Abs(ep.Frame - targetFrame)).First();
            _selectedEditPoint = _editPoints.IndexOf(nearest);
            SetCurrentFrame(nearest.Frame);
        });
    }

    // マウスホイール: 上で-1フレーム、下で+1フレーム
    [JSInvokable]
    public void OnWheel(double deltaY)
    {
        InvokeAsync(() =>
        {
            MoveFrame(deltaY > 0 ? 1 : -1);
        });
    }

    private async Task LoadTrimAdjustSettingsAsync()
    {
        ResetTrimAdjustSettingsToDefault();

        var settingRes = await Api.GetSettingAsync();
        if (!settingRes.Ok || settingRes.Data.ValueKind != JsonValueKind.Object)
        {
            RebuildShortcutLookup();
            return;
        }

        var setting = settingRes.Data;
        _previewScaleMode = NormalizePreviewScaleMode(GetSettingIntOrDefault(setting, TrimAdjustPreviewScaleModeField, 1));
        foreach (var item in _trimCommandSettings)
        {
            _shortcutByCommand[item.CommandId] = NormalizeShortcutOrDefault(
                GetSettingString(setting, item.ShortcutField),
                item.DefaultShortcut);
            if (item.MoveFramesField != null)
            {
                _moveFramesByCommand[item.CommandId] = NormalizeMoveFrames(
                    GetSettingInt(setting, item.MoveFramesField),
                    item.DefaultMoveFrames);
            }
        }
        RebuildShortcutLookup();
    }

    private void ResetTrimAdjustSettingsToDefault()
    {
        _shortcutByCommand.Clear();
        _moveFramesByCommand.Clear();
        _commandByShortcut.Clear();
        _previewScaleMode = 1;
        foreach (var item in _trimCommandSettings)
        {
            _shortcutByCommand[item.CommandId] = item.DefaultShortcut;
            if (item.MoveFramesField != null)
            {
                _moveFramesByCommand[item.CommandId] = item.DefaultMoveFrames;
            }
        }
    }

    private void RebuildShortcutLookup()
    {
        _commandByShortcut.Clear();
        foreach (var item in _trimCommandSettings)
        {
            if (!_shortcutByCommand.TryGetValue(item.CommandId, out var shortcut))
            {
                continue;
            }
            var normalized = NormalizeShortcutOrDefault(shortcut, item.DefaultShortcut);
            _shortcutByCommand[item.CommandId] = normalized;
            if (!_commandByShortcut.ContainsKey(normalized))
            {
                _commandByShortcut[normalized] = item.CommandId;
            }
        }
    }

    private static string GetSettingString(JsonElement setting, string name)
    {
        if (TryGetSettingProperty(setting, name, out var node) && node.ValueKind == JsonValueKind.String)
        {
            return node.GetString() ?? "";
        }
        return "";
    }

    private static int GetSettingInt(JsonElement setting, string name)
    {
        if (!TryGetSettingProperty(setting, name, out var node))
        {
            return 0;
        }
        if (node.ValueKind == JsonValueKind.Number && node.TryGetInt32(out var value))
        {
            return value;
        }
        if (node.ValueKind == JsonValueKind.String && int.TryParse(node.GetString(), out var parsed))
        {
            return parsed;
        }
        return 0;
    }

    private static int GetSettingIntOrDefault(JsonElement setting, string name, int defaultValue)
    {
        if (!TryGetSettingProperty(setting, name, out var node))
        {
            return defaultValue;
        }
        if (node.ValueKind == JsonValueKind.Number && node.TryGetInt32(out var value))
        {
            return value;
        }
        if (node.ValueKind == JsonValueKind.String && int.TryParse(node.GetString(), out var parsed))
        {
            return parsed;
        }
        return defaultValue;
    }

    private static int NormalizePreviewScaleMode(int value)
    {
        return value == 0 || value == 1 || value == 2 ? value : 1;
    }

    private static bool TryGetSettingProperty(JsonElement setting, string name, out JsonElement value)
    {
        if (setting.TryGetProperty(name, out value))
        {
            return true;
        }
        var camel = ToCamelCase(name);
        if (setting.TryGetProperty(camel, out value))
        {
            return true;
        }
        foreach (var item in setting.EnumerateObject())
        {
            if (string.Equals(item.Name, name, StringComparison.OrdinalIgnoreCase))
            {
                value = item.Value;
                return true;
            }
        }
        value = default;
        return false;
    }

    private static string ToCamelCase(string name)
    {
        if (string.IsNullOrEmpty(name))
        {
            return name;
        }
        if (name.Length == 1)
        {
            return name.ToLowerInvariant();
        }
        return char.ToLowerInvariant(name[0]) + name.Substring(1);
    }

    private async Task LoadSessionAsync()
    {
        _loading = true;
        StateHasChanged();
        await LoadTrimAdjustSettingsAsync();

        var result = await Api.CreateTrimSessionAsync(new TrimAdjustSessionRequest
        {
            QueueItemId = QueueItemId,
            ScaleMode = _previewScaleMode
        });

        if (!result.Ok || result.Data == null)
        {
            _errorMessage = result.Error ?? "セッションの作成に失敗しました";
            _loading = false;
            StateHasChanged();
            return;
        }

        _session = result.Data;
        _sessionId = _session.SessionId;
        _currentFrame = 0;

        // TrimsからEditPointsを構築
        RebuildEditPoints(_session.Trims, _session.NumFrames);
        // 初期状態を保存（リセット用）
        _initialEditPoints = _editPoints.Select(e => new EditPoint { Frame = e.Frame }).ToList();

        _loading = false;
        _loadingFrame = 0;
        _displayedFrame = 0;
        _frameImageUrl = "";
        _waveformImageUrl = "";
        _isFrameLoading = false;
        RequestFrameLoad();
        StateHasChanged();

        // プロファイルリスト取得（バックグラウンド）
        _ = LoadProfilesAsync();
        // キューアイテム情報取得（チェックログ検索用）
        _ = LoadQueueItemInfoAsync();
    }

    // プロファイルリストを取得
    private async Task LoadProfilesAsync()
    {
        var res = await Api.GetProfilesAsync();
        if (res.Ok && res.Data != null)
        {
            _profiles = res.Data
                .Select(GetProfileName)
                .Where(n => !string.IsNullOrEmpty(n))
                .Select(n => n!)
                .ToList();
            // 現在のキューアイテムのプロファイルがあればそれを初期選択
            if (!string.IsNullOrEmpty(_queueItemProfileName) && _profiles.Contains(_queueItemProfileName))
            {
                _selectedProfile = _queueItemProfileName;
            }
            else if (_profiles.Count > 0)
            {
                _selectedProfile = _profiles[0];
            }
            StateHasChanged();
        }
    }

    // キューアイテム情報を取得（SrcPath, ProfileName, OutDir, Priority）
    private string? _queueItemProfileName;
    private async Task LoadQueueItemInfoAsync()
    {
        var res = await Api.GetQueueAsync();
        if (res.Ok && res.Data != null)
        {
            var item = res.Data.Items.FirstOrDefault(i => i.Id == QueueItemId);
            if (item != null)
            {
                _queueItemSrcPath = item.SrcPath;
                _queueItemProfileName = item.ProfileName;
                _queueItemOutDir = item.OutDir;
                _queueItemPriority = item.Priority;
                // プロファイルリストが既にロード済みなら選択を更新
                if (!string.IsNullOrEmpty(_queueItemProfileName) && _profiles.Contains(_queueItemProfileName))
                {
                    _selectedProfile = _queueItemProfileName;
                    StateHasChanged();
                }
            }
        }
    }

    private static string? GetProfileName(JsonElement profile)
    {
        if (profile.TryGetProperty("Name", out var nameProp))
            return nameProp.GetString();
        if (profile.TryGetProperty("name", out var namePropLower))
            return namePropLower.GetString();
        return null;
    }

    // セッション再接続（編集点はWebUI側の状態を維持）
    private async Task ReconnectSessionAsync()
    {
        _reconnecting = true;
        _reconnectError = null;
        StateHasChanged();

        var result = await Api.CreateTrimSessionAsync(new TrimAdjustSessionRequest
        {
            QueueItemId = QueueItemId,
            ScaleMode = _previewScaleMode
        });

        if (!result.Ok || result.Data == null)
        {
            _reconnectError = result.Error ?? "再接続に失敗しました（一時フォルダが削除された可能性があります）";
            _reconnecting = false;
            StateHasChanged();
            return;
        }

        // セッション情報を更新、編集点はそのまま維持
        var preservedEditPoints = _editPoints;
        var preservedSelected = _selectedEditPoint;
        var preservedFrame = _currentFrame;
        var preservedHasChanges = _hasChanges;

        _session = result.Data;
        _sessionId = _session.SessionId;

        // フレーム数が変わった場合は編集点・現在フレームをクランプ
        if (_session.NumFrames > 0)
        {
            var selectedFrame = (preservedSelected >= 0 && preservedSelected < preservedEditPoints.Count)
                ? preservedEditPoints[preservedSelected].Frame
                : (int?)null;
            _editPoints = preservedEditPoints
                .Where(e => e.Frame < _session.NumFrames)
                .ToList();
            NormalizeEditPoints(selectedFrame);
            _currentFrame = Math.Clamp(preservedFrame, 0, _session.NumFrames - 1);
        }
        _hasChanges = preservedHasChanges;

        _loadingFrame = _currentFrame;
        _isFrameLoading = false;
        _frameImageUrl = "";
        _waveformImageUrl = "";
        RequestFrameLoad();
        _sessionExpired = false;
        _reconnecting = false;
        _reconnectError = null;
        _imgErrorHandlerSet = false; // onerrorハンドラを再設定させる
        _seekbarHandlerSet = false; // シークバーハンドラを再設定させる
        _wheelHandlerSet = false; // ホイールハンドラを再設定させる

        _statusMessage = "再接続しました";
        _isError = false;
        StateHasChanged();
    }

    // Trimリストから編集点リストを構築
    // Avisynth Trim(end)はinclusiveなので、編集点は end+1 に変換する。
    private void RebuildEditPoints(List<TrimRange> trims, int numFrames)
    {
        _editPoints.Clear();
        if (trims == null || trims.Count == 0 || numFrames <= 0)
        {
            return;
        }

        var points = new List<int>();
        foreach (var trim in trims)
        {
            if (trim.Start >= 0 && trim.Start < numFrames)
            {
                points.Add(trim.Start);
            }

            var endExclusive = (long)trim.End + 1L;
            if (endExclusive >= 0 && endExclusive < numFrames)
            {
                points.Add((int)endExclusive);
            }
        }

        _editPoints = points.Select(frame => new EditPoint { Frame = frame }).ToList();
        NormalizeEditPoints();
    }

    // 編集点リストからTrimリストを再構築（奇数区間=本編のみを保存）
    private List<TrimRange> BuildTrimsFromEditPoints()
    {
        var trims = new List<TrimRange>();
        foreach (var segment in BuildEditPointSegments())
        {
            if (!segment.IsMain)
            {
                continue;
            }
            trims.Add(new TrimRange
            {
                Start = segment.Start,
                End = segment.EndInclusive
            });
        }
        return trims;
    }

    private List<EditPointSegment> BuildEditPointSegments()
    {
        var segments = new List<EditPointSegment>();
        if (_session == null || _session.NumFrames <= 0 || _editPoints.Count == 0)
        {
            return segments;
        }

        for (int i = 0; i < _editPoints.Count; i++)
        {
            var start = _editPoints[i].Frame;
            if (start < 0 || start >= _session.NumFrames)
            {
                continue;
            }

            var hasNext = i + 1 < _editPoints.Count;
            var endExclusive = hasNext ? _editPoints[i + 1].Frame : _session.NumFrames;
            if (endExclusive <= start)
            {
                continue;
            }

            segments.Add(new EditPointSegment
            {
                Index = i,
                Start = start,
                EndInclusive = endExclusive - 1,
                IsOpenEnded = !hasNext
            });
        }

        return segments;
    }

    private string GetEditPointSegmentTail(EditPointSegment segment)
    {
        if (segment.IsOpenEnded)
        {
            return " - ...";
        }
        return $" - {segment.EndInclusive}";
    }

    private void NormalizeEditPoints(int? selectedFrame = null)
    {
        var maxFrame = _session != null ? _session.NumFrames - 1 : int.MaxValue;
        _editPoints = _editPoints
            .Select(e => e.Frame)
            .Where(frame => frame >= 0 && frame <= maxFrame)
            .Distinct()
            .OrderBy(frame => frame)
            .Select(frame => new EditPoint { Frame = frame })
            .ToList();

        if (selectedFrame.HasValue)
        {
            var target = Math.Clamp(selectedFrame.Value, 0, maxFrame);
            _selectedEditPoint = _editPoints.FindIndex(e => e.Frame == target);
            if (_selectedEditPoint < 0 && _editPoints.Count > 0)
            {
                _selectedEditPoint = _editPoints
                    .Select((e, idx) => new { idx, distance = Math.Abs(e.Frame - target) })
                    .OrderBy(x => x.distance)
                    .First()
                    .idx;
            }
        }
        else if (_selectedEditPoint >= _editPoints.Count)
        {
            _selectedEditPoint = _editPoints.Count - 1;
        }
    }

    private void OnEditPointClick(int index)
    {
        _selectedEditPoint = index;
        if (index >= 0 && index < _editPoints.Count)
        {
            SetCurrentFrame(_editPoints[index].Frame);
        }
    }

    // 編集点を初期状態にリセット
    private void ResetEditPoints()
    {
        _editPoints = _initialEditPoints.Select(e => new EditPoint { Frame = e.Frame }).ToList();
        NormalizeEditPoints();
        _selectedEditPoint = -1;
        _hasChanges = false;
        _statusMessage = "編集点をリセットしました";
        _isError = false;
        StateHasChanged();
    }

    private void AddEditPoint()
    {
        if (_session == null)
        {
            return;
        }
        // 現在フレームを編集点として追加
        if (_editPoints.Any(e => e.Frame == _currentFrame))
        {
            return; // 既に存在
        }
        _editPoints.Add(new EditPoint { Frame = _currentFrame });
        NormalizeEditPoints(_currentFrame);
        _hasChanges = true;
        StateHasChanged();
    }

    private void DeleteEditPoint()
    {
        if (_selectedEditPoint < 0 || _selectedEditPoint >= _editPoints.Count)
        {
            return;
        }
        _editPoints.RemoveAt(_selectedEditPoint);
        NormalizeEditPoints();
        if (_selectedEditPoint >= _editPoints.Count)
        {
            _selectedEditPoint = _editPoints.Count - 1;
        }
        _hasChanges = true;
        StateHasChanged();
    }

    private void MoveFrame(int delta)
    {
        SetCurrentFrame(_currentFrame + delta);
    }

    // 画像読み込みリクエスト（ロード中でなければ即座にsrc更新、ロード中ならonload後に自動で次を読み込む）
    private void RequestFrameLoad()
    {
        if (_isFrameLoading) return; // onload時に_currentFrameを拾って次をロードする
        if (_currentFrame == _loadingFrame && _isFrameLoading) return;
        _loadingFrame = _currentFrame;
        _isFrameLoading = true;
        var reqToken = Interlocked.Increment(ref _bundleRequestToken);
        _ = LoadBundleForFrameAsync(_loadingFrame, reqToken);
    }

    private async Task LoadBundleForFrameAsync(int frameNumber, int reqToken)
    {
        if (string.IsNullOrEmpty(_sessionId))
        {
            _isFrameLoading = false;
            return;
        }

        var res = await Api.GetTrimBundleAsync(_sessionId, frameNumber);
        if (reqToken != _bundleRequestToken)
        {
            return;
        }

        if (!res.Ok || res.Data == null || res.Data.VideoJpeg.Length == 0)
        {
            _isFrameLoading = false;
            if (!_sessionExpired && !_loading)
            {
                _sessionExpired = true;
                await InvokeAsync(StateHasChanged);
            }
            return;
        }

        _frameImageUrl = $"data:image/jpeg;base64,{Convert.ToBase64String(res.Data.VideoJpeg)}#r={reqToken}";
        if (res.Data.WaveformJpeg.Length > 0)
        {
            _waveformImageUrl = $"data:image/jpeg;base64,{Convert.ToBase64String(res.Data.WaveformJpeg)}#r={reqToken}";
        }
        else
        {
            _waveformImageUrl = "";
        }
        await InvokeAsync(StateHasChanged);
    }

    // フレーム移動（即時更新：キー/ボタン操作用）
    private void SetCurrentFrame(int frame)
    {
        if (_session == null) return;
        frame = Math.Clamp(frame, 0, _session.NumFrames - 1);
        if (frame == _currentFrame) return;
        _currentFrame = frame;
        // debounceタイマーが残っていればキャンセル
        _debounceTimer?.Dispose();
        _debounceTimer = null;
        RequestFrameLoad();
    }

    // フレーム移動（debounce更新：シークバードラッグ用）
    private void SetCurrentFrameDebounced(int frame)
    {
        if (_session == null) return;
        frame = Math.Clamp(frame, 0, _session.NumFrames - 1);
        if (frame == _currentFrame) return;
        _currentFrame = frame;
        _pendingFrame = _currentFrame;
        _debounceTimer?.Dispose();
        _debounceTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                if (_pendingFrame == _currentFrame)
                {
                    RequestFrameLoad();
                }
            });
        }, null, 100, System.Threading.Timeout.Infinite);
        // 即座にフレーム情報（画面下）だけ更新
        StateHasChanged();
    }

    private void JumpToPrevEditPoint()
    {
        var prev = _editPoints.LastOrDefault(e => e.Frame < _currentFrame);
        if (prev != null)
        {
            _selectedEditPoint = _editPoints.IndexOf(prev);
            SetCurrentFrame(prev.Frame);
        }
        else
        {
            SetCurrentFrame(0);
        }
    }

    private void JumpToNextEditPoint()
    {
        var next = _editPoints.FirstOrDefault(e => e.Frame > _currentFrame);
        if (next != null)
        {
            _selectedEditPoint = _editPoints.IndexOf(next);
            SetCurrentFrame(next.Frame);
        }
        else if (_session != null)
        {
            SetCurrentFrame(_session.NumFrames - 1);
        }
    }

    // 指定フレームがTrim有効区間内かどうか
    private bool IsFrameInTrimRange(int frame)
    {
        return BuildEditPointSegments().Any(s => s.IsMain && frame >= s.Start && frame <= s.EndInclusive);
    }

    // 現在フレームが編集点かどうか
    private bool IsCurrentFrameEditPoint()
    {
        return _editPoints.Any(e => e.Frame == _currentFrame);
    }

    // 編集点の切替（なければ追加、あれば削除）
    private void ToggleEditPoint()
    {
        var existing = _editPoints.FindIndex(e => e.Frame == _currentFrame);
        if (existing >= 0)
        {
            _editPoints.RemoveAt(existing);
            if (_selectedEditPoint >= _editPoints.Count)
                _selectedEditPoint = _editPoints.Count - 1;
        }
        else
        {
            _editPoints.Add(new EditPoint { Frame = _currentFrame });
        }
        NormalizeEditPoints(_currentFrame);
        _hasChanges = true;
        StateHasChanged();
    }

    // シークバーマーカークリックで編集点フレームへ移動
    private void JumpToEditPointFrame(int frame)
    {
        var idx = _editPoints.FindIndex(e => e.Frame == frame);
        if (idx >= 0) _selectedEditPoint = idx;
        SetCurrentFrame(frame);
    }

    private void MoveSelectedEditPointToCurrentFrame()
    {
        if (_selectedEditPoint < 0 || _selectedEditPoint >= _editPoints.Count) return;
        _editPoints[_selectedEditPoint].Frame = _currentFrame;
        NormalizeEditPoints(_currentFrame);
        _hasChanges = true;
        StateHasChanged();
    }

    private async Task SaveTrims()
    {
        if (_session == null || string.IsNullOrEmpty(_sessionId)) return;

        var trims = BuildTrimsFromEditPoints();
        if (trims.Count == 0)
        {
            _statusMessage = "本編区間がありません（編集点を確認してください）";
            _isError = true;
            StateHasChanged();
            return;
        }

        var result = await Api.SaveTrimsAsync(_sessionId, new TrimSaveRequest { Trims = trims });
        if (result.Ok)
        {
            _statusMessage = "保存しました";
            _isError = false;
            _hasChanges = false;
        }
        else
        {
            // セッション切れの可能性を検出（セッションが見つからないエラー）
            var err = result.Error ?? "";
            if (err.Contains("セッション") || err.Contains("session", StringComparison.OrdinalIgnoreCase))
            {
                _sessionExpired = true;
            }
            _statusMessage = result.Error ?? "保存に失敗しました";
            _isError = true;
        }
        StateHasChanged();
    }

    // チェックログ表示
    private async Task ShowCheckLog()
    {
        _checkLogLoading = true;
        _checkLogError = null;
        _checkLogContent = null;
        _checkLogTitle = null;
        _checkLogVisible = true;
        StateHasChanged();

        // チェックログ一覧から該当アイテムのログを探す
        var logsRes = await Api.GetCheckLogsAsync();
        if (!logsRes.Ok || logsRes.Data == null)
        {
            _checkLogError = logsRes.Error ?? "チェックログの取得に失敗しました";
            _checkLogLoading = false;
            StateHasChanged();
            return;
        }

        // SrcPathが一致する最新のチェックログを取得
        var matchLog = logsRes.Data
            .Where(l => !string.IsNullOrEmpty(_queueItemSrcPath) && l.SrcPath == _queueItemSrcPath)
            .OrderByDescending(l => l.CheckStartDate)
            .FirstOrDefault();

        if (matchLog == null)
        {
            _checkLogError = "該当するチェックログが見つかりません";
            _checkLogLoading = false;
            StateHasChanged();
            return;
        }

        _checkLogTitle = System.IO.Path.GetFileName(matchLog.SrcPath);

        var detailRes = await Api.GetLogFileAsync(null, matchLog.CheckStartDate);
        if (!detailRes.Ok || detailRes.Data == null)
        {
            _checkLogError = detailRes.Error ?? "ログ詳細の取得に失敗しました";
        }
        else
        {
            _checkLogContent = detailRes.Data;
        }
        _checkLogLoading = false;
        StateHasChanged();
    }

    private void CloseCheckLog()
    {
        _checkLogVisible = false;
    }

    // プロファイルを指定して再投入（保存→通常モードの新規タスクを追加）
    private async Task RequeueWithProfile()
    {
        if (string.IsNullOrEmpty(_selectedProfile)) return;
        _requeueBusy = true;
        StateHasChanged();

        // 1. 編集点を保存
        if (_hasChanges)
        {
            await SaveTrims();
            if (_isError)
            {
                _requeueBusy = false;
                StateHasChanged();
                return;
            }
        }

        if (string.IsNullOrEmpty(_queueItemSrcPath))
        {
            _statusMessage = "元の入力ファイル情報が取得できません";
            _isError = true;
            _requeueBusy = false;
            StateHasChanged();
            return;
        }

        if (string.IsNullOrEmpty(_queueItemOutDir))
        {
            _statusMessage = "元の出力先情報が取得できません";
            _isError = true;
            _requeueBusy = false;
            StateHasChanged();
            return;
        }

        // 2. 通常モードの新規タスクとして追加
        var addRes = await Api.AddQueueAsync(new AddQueueRequest
        {
            Mode = ProcMode.Batch,
            Targets = new List<AddQueueItem>()
            {
                new AddQueueItem()
                {
                    Path = _queueItemSrcPath
                }
            },
            Outputs = new List<OutputInfo>()
            {
                new OutputInfo()
                {
                    DstPath = _queueItemOutDir,
                    Profile = _selectedProfile,
                    Priority = _queueItemPriority
                }
            }
        });

        if (addRes.Ok)
        {
            _statusMessage = "再投入しました";
            _isError = false;
            _requeueBusy = false;
            StateHasChanged();
            await Task.Delay(500);
            await JS.InvokeVoidAsync("trimAdjustCloseWindow");
            return;
        }
        else
        {
            _statusMessage = addRes.Error ?? "再投入に失敗しました";
            _isError = true;
        }

        _requeueBusy = false;
        StateHasChanged();
    }

    private void ExecuteTrimCommand(string commandId)
    {
        switch (commandId)
        {
            case TrimCmdPrevEditPoint:
                JumpToPrevEditPoint();
                break;
            case TrimCmdNextEditPoint:
                JumpToNextEditPoint();
                break;
            case TrimCmdToggleEditPoint:
                ToggleEditPoint();
                break;
            default:
                var delta = GetMoveDelta(commandId);
                if (delta != 0)
                {
                    MoveFrame(delta);
                }
                break;
        }
    }

    private string GetTrimCommandTooltip(string commandId)
    {
        var shortcut = GetShortcutLabel(commandId);
        return commandId switch
        {
            TrimCmdPrevEditPoint => $"前の編集点へ ({shortcut})",
            TrimCmdNextEditPoint => $"次の編集点へ ({shortcut})",
            TrimCmdToggleEditPoint => $"編集点切替 ({shortcut})",
            _ => $"{GetMoveDeltaText(commandId)} ({shortcut})"
        };
    }

    private string GetMoveDeltaText(string commandId)
    {
        var delta = GetMoveDelta(commandId);
        return $"{(delta > 0 ? "+" : "")}{delta}F";
    }

    private string GetTrimCommandDistanceLabel(string commandId)
    {
        return commandId switch
        {
            TrimCmdPrevEditPoint => "前編集点",
            TrimCmdNextEditPoint => "次編集点",
            TrimCmdToggleEditPoint => "切替",
            _ => GetMoveDeltaText(commandId).ToLowerInvariant()
        };
    }

    private int GetMoveDelta(string commandId)
    {
        return commandId switch
        {
            TrimCmdBack4 => -GetConfiguredMoveFrames(TrimCmdBack4),
            TrimCmdBack3 => -GetConfiguredMoveFrames(TrimCmdBack3),
            TrimCmdBack2 => -GetConfiguredMoveFrames(TrimCmdBack2),
            TrimCmdBack1 => -1,
            TrimCmdForward1 => 1,
            TrimCmdForward2 => GetConfiguredMoveFrames(TrimCmdForward2),
            TrimCmdForward3 => GetConfiguredMoveFrames(TrimCmdForward3),
            TrimCmdForward4 => GetConfiguredMoveFrames(TrimCmdForward4),
            _ => 0
        };
    }

    private int GetConfiguredMoveFrames(string commandId)
    {
        if (_moveFramesByCommand.TryGetValue(commandId, out var value) && value > 0)
        {
            return value;
        }
        if (_trimCommandSettingMap.TryGetValue(commandId, out var setting))
        {
            return setting.DefaultMoveFrames > 0 ? setting.DefaultMoveFrames : 1;
        }
        return 1;
    }

    private string GetShortcutLabel(string commandId)
    {
        if (_shortcutByCommand.TryGetValue(commandId, out var shortcut))
        {
            return FormatShortcutLabel(shortcut);
        }
        if (_trimCommandSettingMap.TryGetValue(commandId, out var setting))
        {
            return FormatShortcutLabel(setting.DefaultShortcut);
        }
        return "-";
    }

    private static string BuildShortcutFromEvent(KeyboardEventArgs e)
    {
        var key = NormalizeShortcutKey(e.Key);
        if (string.IsNullOrEmpty(key))
        {
            return "";
        }
        var parts = new List<string>();
        if (e.CtrlKey) parts.Add("Ctrl");
        if (e.ShiftKey) parts.Add("Shift");
        if (e.AltKey) parts.Add("Alt");
        parts.Add(key);
        return string.Join("+", parts);
    }

    private static string NormalizeShortcutOrDefault(string value, string defaultValue)
    {
        var normalized = NormalizeShortcutText(value);
        return string.IsNullOrEmpty(normalized) ? defaultValue : normalized;
    }

    private static string NormalizeShortcutText(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "";
        }
        var ctrl = false;
        var shift = false;
        var alt = false;
        string? key = null;
        var parts = value.Split('+', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        foreach (var part in parts)
        {
            var token = part.Trim();
            if (token.Equals("ctrl", StringComparison.OrdinalIgnoreCase) ||
                token.Equals("control", StringComparison.OrdinalIgnoreCase))
            {
                ctrl = true;
                continue;
            }
            if (token.Equals("shift", StringComparison.OrdinalIgnoreCase))
            {
                shift = true;
                continue;
            }
            if (token.Equals("alt", StringComparison.OrdinalIgnoreCase) ||
                token.Equals("option", StringComparison.OrdinalIgnoreCase))
            {
                alt = true;
                continue;
            }
            key = NormalizeShortcutKey(token);
        }
        if (string.IsNullOrEmpty(key))
        {
            return "";
        }
        var result = new List<string>();
        if (ctrl) result.Add("Ctrl");
        if (shift) result.Add("Shift");
        if (alt) result.Add("Alt");
        result.Add(key);
        return string.Join("+", result);
    }

    private static string NormalizeShortcutKey(string key)
    {
        if (string.IsNullOrEmpty(key))
        {
            return "";
        }
        return key switch
        {
            " " => "Space",
            "Spacebar" => "Space",
            "Space" => "Space",
            "Left" => "ArrowLeft",
            "Right" => "ArrowRight",
            "Up" => "ArrowUp",
            "Down" => "ArrowDown",
            "ArrowLeft" => "ArrowLeft",
            "ArrowRight" => "ArrowRight",
            "ArrowUp" => "ArrowUp",
            "ArrowDown" => "ArrowDown",
            "Tab" => "",
            "Control" => "",
            "Shift" => "",
            "Alt" => "",
            "Meta" => "",
            "OS" => "",
            "Process" => "",
            _ => key.Length == 1 ? key.ToUpperInvariant() : key
        };
    }

    private static string FormatShortcutLabel(string shortcut)
    {
        if (string.IsNullOrWhiteSpace(shortcut))
        {
            return "-";
        }
        var parts = shortcut.Split('+', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        for (var i = 0; i < parts.Length; i++)
        {
            parts[i] = parts[i] switch
            {
                "ArrowLeft" => "Left",
                "ArrowRight" => "Right",
                "ArrowUp" => "Up",
                "ArrowDown" => "Down",
                _ => parts[i]
            };
        }
        return string.Join("+", parts);
    }

    private static int NormalizeMoveFrames(int value, int defaultValue)
    {
        return value > 0 ? value : defaultValue;
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        var shortcut = BuildShortcutFromEvent(e);
        if (!string.IsNullOrEmpty(shortcut) && _commandByShortcut.TryGetValue(shortcut, out var commandId))
        {
            ExecuteTrimCommand(commandId);
            return;
        }
        switch (e.Key)
        {
            case "i":
            case "I":
                MoveSelectedEditPointToCurrentFrame();
                break;
            case "s":
            case "S":
                _ = SaveTrims();
                break;
            case "Delete":
                DeleteEditPoint();
                break;
        }
    }

    // ヘルパーメソッド

    private string FormatTime(int frame)
    {
        if (_session?.FramePts == null || frame < 0 || frame >= _session.FramePts.Count)
        {
            return "--:--:--.---";
        }
        var seconds = _session.FramePts[frame];
        // 先頭フレームを0秒基準にする
        if (_session.FramePts.Count > 0)
        {
            seconds -= _session.FramePts[0];
        }
        if (seconds < 0) seconds = 0;
        var ts = TimeSpan.FromSeconds(seconds);
        return $"{(int)ts.TotalHours:D2}:{ts.Minutes:D2}:{ts.Seconds:D2}.{ts.Milliseconds:D3}";
    }

    private string GetFramePercent(int frame)
    {
        if (_session == null || _session.NumFrames <= 1) return "0";
        var pct = (double)frame / (_session.NumFrames - 1) * 100.0;
        return pct.ToString("F4", CultureInfo.InvariantCulture);
    }

    // シークバーのグラデーション: 奇数区間(本編)をオレンジ、その他をグレーで表示
    private string GetSeekBarGradient()
    {
        if (_session == null || _session.NumFrames <= 1)
        {
            return "background: #666;";
        }

        var segments = BuildEditPointSegments();
        if (segments.Count == 0)
        {
            return "background: #666;";
        }

        var total = _session.NumFrames - 1;
        var stops = new List<string>();
        var lastPct = 0.0;

        foreach (var segment in segments)
        {
            var startPct = (double)segment.Start / total * 100.0;
            var endPct = (double)segment.EndInclusive / total * 100.0;
            var color = segment.IsMain ? "#e88030" : "#555";

            if (startPct > lastPct)
            {
                stops.Add($"#555 {lastPct.ToString("F2", CultureInfo.InvariantCulture)}%");
                stops.Add($"#555 {startPct.ToString("F2", CultureInfo.InvariantCulture)}%");
            }
            stops.Add($"{color} {startPct.ToString("F2", CultureInfo.InvariantCulture)}%");
            stops.Add($"{color} {endPct.ToString("F2", CultureInfo.InvariantCulture)}%");
            lastPct = endPct;
        }

        if (lastPct < 100.0)
        {
            stops.Add($"#555 {lastPct.ToString("F2", CultureInfo.InvariantCulture)}%");
            stops.Add($"#555 100%");
        }

        return $"background: linear-gradient(to right, {string.Join(", ", stops)});";
    }

    public async ValueTask DisposeAsync()
    {
        _debounceTimer?.Dispose();
        _objRef?.Dispose();
        if (!string.IsNullOrEmpty(_sessionId))
        {
            await Api.DeleteTrimSessionAsync(_sessionId);
        }
    }
